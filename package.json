{
  "name": "tabletop",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted, open-source board game collection and play-session tracker",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace apps/server",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^26.1.0",
    "dotenv": "^17.4.2",
    "@vitest/coverage-v8": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "c12": {
      "magicast": "^0.3.5"
    },
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
