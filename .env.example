# ---- Database ----
DB_HOST=db
DB_PORT=5432
DB_USER=tabletop
DB_PASSWORD=changeme
DB_NAME=tabletop
# Prisma connection string (derived from the above in compose; set directly for local dev)
DATABASE_URL=postgresql://tabletop:changeme@localhost:5432/tabletop

# ---- Auth (REQUIRED — app fails fast if unset) ----
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars
JWT_REFRESH_SECRET=replace_with_a_different_64_hex_chars

# ---- App ----
PORT=5470
TZ=UTC
DEFAULT_CURRENCY=NOK
DEFAULT_LOCALE=en

# ---- BGG sync (v2 seam, disabled by default) ----
BGG_SYNC_ENABLED=false
BGG_SYNC_PROVIDER=csv
BGG_API_TOKEN=
